{
  "family": "transitbdg",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::879989086304:role/transitbdg-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::879989086304:role/transitbdg-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "backend",
      "image": "879989086304.dkr.ecr.ap-southeast-1.amazonaws.com/transitbdg-backend:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "3000" },
        { "name": "AWS_REGION", "value": "ap-southeast-1" },
        { "name": "DB_SSL", "value": "true" },
        { "name": "CORS_ORIGIN", "value": "*" }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:ssm:ap-southeast-1:879989086304:parameter/transitbdg/DATABASE_URL"
        },
        {
          "name": "JWT_SECRET",
          "valueFrom": "arn:aws:ssm:ap-southeast-1:879989086304:parameter/transitbdg/JWT_SECRET"
        },
        {
          "name": "S3_BUCKET",
          "valueFrom": "arn:aws:ssm:ap-southeast-1:879989086304:parameter/transitbdg/S3_BUCKET"
        },
        {
          "name": "CLOUDFRONT_URL",
          "valueFrom": "arn:aws:ssm:ap-southeast-1:879989086304:parameter/transitbdg/CLOUDFRONT_URL"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/transitbdg-backend",
          "awslogs-region": "ap-southeast-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    },
    {
      "name": "frontend",
      "image": "879989086304.dkr.ecr.ap-southeast-1.amazonaws.com/transitbdg-frontend:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/transitbdg-frontend",
          "awslogs-region": "ap-southeast-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
